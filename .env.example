# LO_Bot_Host — copy to .env and fill in the blanks.
# NEVER put Steam account passwords here. They are entered interactively via
# VNC on first run and persist in the per-instance Steam volume.

# --- Competition server link (shared across instances) ---
# If the competition server runs in Docker on the same host and you joined
# its external network in docker-compose.yml, use the service name:
#   COMPETITION_SERVER_URL=ws://realtime:3000/plugin
# If the server runs on the host (not Docker), use host.docker.internal:
#   COMPETITION_SERVER_URL=ws://host.docker.internal:3000/plugin
COMPETITION_SERVER_URL=ws://host.docker.internal:3000/plugin

# --- Per-bot API keys ---
# Pre-register each key in the competition server's `bots` table. Each key maps
# to a distinct botId server-side. Generate with `openssl rand -hex 32` or
# through the server's admin UI.
PLUGIN_API_KEY_1=
PLUGIN_API_KEY_2=
PLUGIN_API_KEY_3=

# --- Display labels only (used in logs and banners; never treat as secret) ---
STEAM_USER_1=bot-alpha
STEAM_USER_2=bot-bravo
STEAM_USER_3=bot-charlie

# --- Virtual display ---
# 1280x720 is the sweet spot for a GTX 1650 with 3 concurrent instances.
# Drop to 1024x576 if nvidia-smi shows VRAM pressure.
DISPLAY_RESOLUTION=1280x720

# --- VNC binding ---
# 127.0.0.1 means VNC is reachable only via SSH tunnel. DO NOT set to 0.0.0.0
# unless you have a strong VNC password and accept the exposure risk.
VNC_BIND_ADDR=127.0.0.1

# Uncomment to allow VNC with no password (development convenience only;
# ./secrets/vnc-passwd must still be absent).
# ALLOW_UNAUTH_VNC=1
